# Environment secrets — NEVER commit
.env

# Watcher persistent state (processed IDs, OAuth tokens)
watchers/.state/

# Credentials and secrets
watchers/.secrets/

# Playwright browser session data
.sessions/
.whatsapp_session/
.linkedin_session/

# Selector diagnostic artifacts (generated by debug_*.py scripts)
watchers/debug_*.html
watchers/debug_*.png

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Logs
logs/

# Node
node_modules/
package-lock.json

# OS
.DS_Store
Thumbs.db

# Vault runtime data — contains PII (emails, names, audit logs)
vault/Logs/*.jsonl
vault/Logs/planning_state.json
vault/Logs/rate_limit.json
vault/Logs/metrics.json
vault/Done/
vault/Approved/
vault/Rejected/
vault/Failed/
vault/Inbox/
vault/Redacted/
vault/Archive/

# Local Claude settings
.claude/settings.local.json
